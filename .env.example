APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_PATH=./instance/private_chat.sqlite3

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
TRUST_PROXY_HEADERS=true
SOCKET_IO_CORS_ORIGINS=https://your-frontend-url

PRIVATE_ACCOUNT_1_USERNAME=usman
PRIVATE_ACCOUNT_1_DISPLAY_NAME=Usman
PRIVATE_ACCOUNT_1_PASSWORD=usman07

PRIVATE_ACCOUNT_2_USERNAME=aisha
PRIVATE_ACCOUNT_2_DISPLAY_NAME=Aisha
PRIVATE_ACCOUNT_2_PASSWORD=aisha123

LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
BOT_WORDLIST_MAX_UPLOAD_BYTES=5000000
BOT_WORDLIST_MAX_LINES=100000

# Optional frontend overrides for split deployments
VITE_API_BASE_URL=https://your-backend-url
VITE_SOCKET_URL=https://your-backend-url
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:5000
